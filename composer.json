{
    "name": "emagister/collections",
    "type": "library",
    "description": "The Emagister Collections project provides a set of collection classes for PHP.",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Emagister\\Collections\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Emagister\\Collections\\Tests\\": "tests",
            "Emagister\\Collections\\Examples\\": "examples"
        }
    },
    "config": {
        "platform": {
            "php": "8.1.0"
        }
    },
    "scripts": {
        "lint": "find src tests -name '*.php' -exec php -l {} \\;",
        "tests": "phpunit",
        "phpcs": "phpcs",
        "cs-fixer": "php-cs-fixer fix --dry-run --diff --allow-risky=yes"
    },
    "version": "1.3.2"
}
